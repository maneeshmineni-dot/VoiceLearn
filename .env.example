# Flask secret key — change this in production
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── AI Providers ────────────────────────────────────────────────────────────
# Priority: Gemini (primary) → ChatGPT (alternative) → Claude (premium)

# Gemini — server-side fallback key (used when user has no Gemini key in browser)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OpenAI and Claude are BYOK only (user enters in Settings modal).
# You can optionally add server-side keys here for testing:
# OPENAI_API_KEY=sk-proj-...
# CLAUDE_API_KEY=sk-ant-...
